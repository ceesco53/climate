# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── GitHub / Registry ─────────────────────────────────────────────────────────
# Your GitHub username (used as the container registry namespace on ghcr.io)
GITHUB_USER=ceesco53
# GitHub personal access token with packages:write and read:packages scopes
# Generate at: https://github.com/settings/tokens → "Generate new token (classic)"
# Required scopes: write:packages, read:packages, delete:packages
GITHUB_TOKEN=ghp_REPLACE_ME

# ── Google Cloud OAuth 2.0 ────────────────────────────────────────────────────
# Created in Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# See README.md "Step 1: Google Cloud Console" for full walkthrough.
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-REPLACE_ME

# ── Nest Device Access ────────────────────────────────────────────────────────
# Project ID from the Nest Device Access Console (console.nest.google.com/device-access)
# See README.md "Step 2: Nest Device Access Console" for full walkthrough.
# Requires a one-time $5 USD fee.
SDM_PROJECT_ID=REPLACE_ME

# ── Google OAuth Refresh Token ────────────────────────────────────────────────
# Obtained by visiting https://climate.ingress.realmclick.com/api/auth/start
# after the app is deployed. The app stores it in the database automatically.
# You can leave this blank on first deploy, then run build-push.sh again after
# authorizing via the web UI to sync it into the k8s secret.
# See README.md "Step 4: Authorize the App" for the full flow.
GOOGLE_REFRESH_TOKEN=

# ── Thermostat Device IDs ─────────────────────────────────────────────────────
# Retrieved by calling: curl https://climate.ingress.realmclick.com/api/devices
# after completing the OAuth flow above.
# Each value is the short alphanumeric ID at the end of the SDM device name path.
# See README.md "Step 5: Identify Your Thermostats" for the full flow.
UPSTAIRS_DEVICE_ID=
DOWNSTAIRS_DEVICE_ID=
